@{
    ViewData["Title"] = "Domů";
}

<div class="text-center">
    <h1 class="display-4 fw-bold">BLOGIC CRM</h1>
    <p class="lead">Vyberte možnost, kterou chcete spravovat:</p>
</div>

<div class="row mt-4 justify-content-center">
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm">
            <div class="card-body text-center p-4">
                <h5 class="card-title mb-4">Smlouvy</h5>
                <a asp-controller="Smlouva" asp-action="Index" class="btn btn-primary btn-lg w-100">Zobrazit smlouvy</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm">
            <div class="card-body text-center p-4">
                <h5 class="card-title mb-4">Klienti</h5>
                <a asp-controller="Klient" asp-action="Index" class="btn btn-primary btn-lg w-100">Zobrazit klienty</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm">
            <div class="card-body text-center p-4">
                <h5 class="card-title mb-4">Poradci</h5>
                <a asp-controller="Poradce" asp-action="Index" class="btn btn-primary btn-lg w-100">Zobrazit poradce</a>
            </div>
        </div>
    </div>
</div>