@model BLOGIC_CRM.ViewModels.SmlouvaCreateViewModel

@{
    ViewData["Title"] = "Nová Smlouva";
}

<h1>Vytvořit novou smlouvu</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="EvidencniCislo" class="control-label"></label>
                <input asp-for="EvidencniCislo" class="form-control" />
                <span asp-validation-for="EvidencniCislo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Instituce" class="control-label"></label>
                <input asp-for="Instituce" class="form-control" />
                <span asp-validation-for="Instituce" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="KlientId" class="control-label"></label>
                <select asp-for="KlientId" class="form-control" asp-items="Model.KlientiList">
                    <option value="">-- Vyberte klienta --</option>
                </select>
                <span asp-validation-for="KlientId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SpravceId" class="control-label"></label>
                <select asp-for="SpravceId" class="form-control" asp-items="Model.PoradciList">
                    <option value="">-- Vyberte správce --</option>
                </select>
                <span asp-validation-for="SpravceId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="VybraniUcastniciIds" class="control-label"></label>
                <select asp-for="VybraniUcastniciIds" class="form-control" asp-items="Model.PoradciList" multiple="multiple" size="5">
                </select>
                <span asp-validation-for="VybraniUcastniciIds" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DatumUzavreni" class="control-label"></label>
                <input asp-for="DatumUzavreni" class="form-control" />
                <span asp-validation-for="DatumUzavreni" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DatumPlatnosti" class="control-label"></label>
                <input asp-for="DatumPlatnosti" class="form-control" />
                <span asp-validation-for="DatumPlatnosti" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DatumUkonceni" class="control-label"></label>
                <input asp-for="DatumUkonceni" class="form-control" />
                <span asp-validation-for="DatumUkonceni" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Vytvořit" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Zpět na seznam</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}                       