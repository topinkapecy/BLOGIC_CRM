@model IEnumerable<BLOGIC_CRM.Models.Smlouva>

@{
    ViewData["Title"] = "Smlouvy";
}

<h1>Smlouvy</h1>

<p>
    <a asp-action="Create">Vytvořit novou smlouvu</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.EvidencniCislo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Klient)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SpravceSmlouvy)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Instituce)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumUzavreni)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumPlatnosti)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumUkonceni)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.EvidencniCislo)
            </td>
            <td>
                @Html.DisplayFor(model => item.Klient.CeleJmeno)
            </td>
            <td>
                @Html.DisplayFor(model => item.SpravceSmlouvy.CeleJmeno)
            </td>
            <td>
                @Html.DisplayFor(model => item.DatumUzavreni)
            </td>
            <td>
                @Html.DisplayFor(model => item.DatumPlatnosti)
            </td>
            <td>
                @Html.DisplayFor(model => item.DatumUkonceni)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Upravit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Detaily</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Smazat</a>
            </td>
        </tr>
}
    </tbody>
</table>
