@model IEnumerable<BLOGIC_CRM.Models.Poradce>

@{
    ViewData["Title"] = "Poradci";
}

<h1>Poradci</h1>

<p>
    <a asp-action="Create">Vytvořit nového poradce</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Jmeno)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prijmeni)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Telefon)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RodneCislo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vek)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SpravovaneSmlouvy)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Jmeno)
            </td>
            <td>
                @Html.DisplayFor(model => item.Prijmeni)
            </td>
            <td>
                @Html.DisplayFor(model => item.Email)
            </td>
            <td>
                @Html.DisplayFor(model => item.Telefon)
            </td>
            <td>
                @Html.DisplayFor(model => item.RodneCislo)
            </td>
            <td>
                @Html.DisplayFor(model => item.Vek)
            </td>
            <td>
                @Html.DisplayFor(model => item.SpravovaneSmlouvy)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Upravit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Detaily</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Smazat</a>
            </td>
        </tr>
}
    </tbody>
</table>
